<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean class="ubb.dbsm.domain.validator.TankValidator" id="tankValidator"/>

    <bean class="ubb.dbsm.repository.DBRepository.CountryDAO" id="countryDAO"/>
    <bean class="ubb.dbsm.repository.DBRepository.ManufacturerDAO" id="manufacturerDAO"/>
    <bean class="ubb.dbsm.repository.DBRepository.TankDAO" id="tankDAO"/>

    <bean class="ubb.dbsm.repository.DBRepository.paged.TankPagedDAO" id="tankPagedDAO"/>
    <bean class="ubb.dbsm.repository.DBRepository.paged.ManufacturerPagedDAO" id="manufacturerPagedDAO"/>

    <bean class="ubb.dbsm.service.model.ManufacturerService" id="manufacturerService">
        <constructor-arg ref="manufacturerPagedDAO"/>
    </bean>
    <bean class="ubb.dbsm.service.model.TankService" id="tankService">
        <constructor-arg ref="tankPagedDAO"/>
        <constructor-arg ref="tankValidator"/>
    </bean>

    <bean class="ubb.dbsm.controller.MainController" id="mainController">
        <constructor-arg ref="tankService"/>
        <constructor-arg ref="manufacturerService"/>
    </bean>
</beans>