<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-create-table-tank_info" author="Crocodin">
        <createTable tableName="tank_info">
            <column name="tank_info_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_tank_info_id"/>
            </column>
            <column name="about" type="varchar(250)"/>
            <column name="tank_id" type="int">
                <constraints foreignKeyName="fk_tank_info_tank_id"
                             referencedTableName="tank"
                             referencedColumnNames="tank_id"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>